# ProxyAPI — единый ключ для Claude (Anthropic) и OpenAI Images (gpt-image-2)
PROXYAPI_KEY=ваш_ключ_от_proxyapi

# Kling AI (для генерации изображений)
KLING_ACCESS_KEY=ваш_kling_access_key
KLING_SECRET_KEY=ваш_kling_secret_key
# Регион Kling. По умолчанию международный (для аккаунтов с app.klingai.com/global/dev).
# Раскомментируй нужный, если твой аккаунт другого региона:
# KLING_BASE_URL=https://api-singapore.klingai.com   # международный (по умолчанию)
# KLING_BASE_URL=https://api.klingai.com             # китайский (kling.kuaishou.com)

# === VK ID OAuth 2.1 (v0.3 — для медиа-публикации) ===
# Standalone-приложение, созданное через id.vk.com (НЕ мини-приложение).
VK_OAUTH_APP_ID=54587420

# Redirect URI — точное совпадение с одним из «Доверенных redirect URI» в Self
# Service приложения. Для manual-paste flow используем blank-страницу VK
# (VK ID требует HTTPS, http://localhost не принимается).
VK_OAUTH_REDIRECT_URI=https://oauth.vk.com/blank.html

# Идентификатор устройства/клиента — UUID (hex, 32 символа), генерируется при
# ПЕРВОЙ авторизации в scripts/get_vk_token.py и затем не меняется. Обязателен
# в каждом refresh-запросе на /oauth2/auth. НЕ заполнять руками.
VK_OAUTH_DEVICE_ID=

# Токены — заполняются автоматически после OAuth-flow.
# Не трогать руками после первой авторизации.
VK_USER_ACCESS_TOKEN=
VK_USER_REFRESH_TOKEN=
VK_USER_TOKEN_EXPIRES_AT=

# === Старые переменные (deprecated, fallback) ===
# Если VK_USER_ACCESS_TOKEN пустой — приложение откатится на этот токен.
# Текстовая публикация будет работать, медиа — упадёт с code 27.
VK_COMMUNITY_TOKEN=
# Числовой id сообщества (положительное число, без минуса). Узнать: https://regvk.com/id/
VK_GROUP_ID=числовой_id_сообщества
VK_API_VERSION=5.199

# Flask
FLASK_SECRET_KEY=сгенерируйте_случайную_строку_32_символа
FLASK_ENV=development

# Параметры генерации (можно менять без перезапуска)
LLM_MODEL=claude-opus-4-7
LLM_MAX_TOKENS=2000

# OpenAI Images через ProxyAPI (для генерации картинок в приложении)
OPENAI_IMAGE_MODEL=gpt-image-2
